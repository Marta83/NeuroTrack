rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(patientId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/patients/$(patientId)).data.ownerUserId
            == request.auth.uid;
    }

    match /patients/{patientId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUserId == request.auth.uid;

      allow read, update, delete: if isSignedIn()
        && resource.data.ownerUserId == request.auth.uid;

      match /history/{historyId} {
        allow create, read: if isOwner(patientId);
      }

      match /medication_history/{entryId} {
        allow create, read, update, delete: if isOwner(patientId);
      }
    }

    match /seizures/{seizureId} {
      allow create: if isSignedIn()
        && request.resource.data.patientId is string
        && isOwner(request.resource.data.patientId);

      allow read, update, delete: if isSignedIn()
        && isOwner(resource.data.patientId);
    }
  }
}
